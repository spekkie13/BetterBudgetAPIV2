datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Team {
  id    Int    @id @default(autoincrement())
  Name  String
  Users User[]
}

model User {
  id                 Int                  @id @default(autoincrement())
  Name               String
  Username           String
  Email              String               @unique
  Team               Team?                @relation(fields: [teamId], references: [id])
  teamId             Int?
  Preferences        UserPreference[]
  Categories         Category[]
  Expenses           Expense[]
  Budgets            PeriodBudget[]
  RecentPeriodResult RecentPeriodResult[]
}

model UserPreference {
  id          Int      @id @default(autoincrement())
  Name        String
  StringValue String
  NumberValue Int
  DateValue   DateTime
  User        User?    @relation(fields: [userId], references: [id])
  userId      Int?
}

model Category {
  id       Int                  @id @default(autoincrement())
  Name     String
  Color    String
  Icon     String
  User     User?                @relation(fields: [userId], references: [id])
  userId   Int?
  Expenses Expense[]
  Budgets  PeriodBudget[]
  Results  RecentPeriodResult[]
}

model Expense {
  id          Int       @id @default(autoincrement())
  Date        DateTime
  Amount      Decimal
  Description String
  IsRecurring Boolean
  User        User?     @relation(fields: [userId], references: [id])
  userId      Int?
  Category    Category? @relation(fields: [categoryId], references: [id])
  categoryId  Int?
}

model PeriodBudget {
  id         Int       @id @default(autoincrement())
  Budget     Decimal
  Month      Int
  Year       Int
  User       User?     @relation(fields: [userId], references: [id])
  userId     Int?
  Category   Category? @relation(fields: [categoryId], references: [id])
  categoryId Int?
}

model RecentPeriodResult {
  id         Int       @id @default(autoincrement())
  Spent      Decimal
  User       User?     @relation(fields: [userId], references: [id])
  userId     Int?
  Category   Category? @relation(fields: [categoryId], references: [id])
  categoryId Int?
}

model DateObj {
  id    Int @id @default(autoincrement())
  Year  Int
  Month Int
}
