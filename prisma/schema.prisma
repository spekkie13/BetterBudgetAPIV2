datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id          Int              @id @default(autoincrement())
  email       String           @unique
  username    String           @unique
  name        String
  teamId      Int?
  team        Team?            @relation(fields: [teamId], references: [id])
  categories  Category[]
  expenses    Expense[]
  incomes     Income[]
  budgets     Budget[]
  results     Result[]
  preferences UserPreference[]
}

model Team {
  id    Int    @id @default(autoincrement())
  name  String
  users User[]
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String
  color String
  icon  String

  user   User @relation(fields: [userId], references: [id])
  userId Int

  expenses Expense[]
  budgets  Budget[]
  results  Result[]
}

model Expense {
  id          Int      @id @default(autoincrement())
  description String
  amount      Decimal  @db.Decimal(10, 2)
  date        DateTime
  isRecurring Boolean

  user   User @relation(fields: [userId], references: [id])
  userId Int

  category   Category @relation(fields: [categoryId], references: [id])
  categoryId Int
}

model Income {
  id     Int      @id @default(autoincrement())
  amount Decimal  @db.Decimal(10, 2)
  date   DateTime

  user   User @relation(fields: [userId], references: [id])
  userId Int
}

model Period {
  id        Int      @id @default(autoincrement())
  startDate DateTime
  endDate   DateTime

  budgets Budget[]
  results Result[]
}

model Budget {
  id     Int     @id @default(autoincrement())
  amount Decimal @db.Decimal(10, 2)

  user   User @relation(fields: [userId], references: [id])
  userId Int

  category   Category @relation(fields: [categoryId], references: [id])
  categoryId Int

  period   Period @relation(fields: [periodId], references: [id])
  periodId Int
}

model Result {
  id              Int     @id @default(autoincrement())
  totalSpent      Decimal @db.Decimal(10, 2)
  percentageSpent Decimal @db.Decimal(5, 2)

  user   User @relation(fields: [userId], references: [id])
  userId Int

  category   Category @relation(fields: [categoryId], references: [id])
  categoryId Int

  period   Period @relation(fields: [periodId], references: [id])
  periodId Int
}

model UserPreference {
  id          Int       @id @default(autoincrement())
  name        String
  stringValue String? // optional values for flexibility
  numberValue Float?
  dateValue   DateTime?

  user   User @relation(fields: [userId], references: [id])
  userId Int
}
